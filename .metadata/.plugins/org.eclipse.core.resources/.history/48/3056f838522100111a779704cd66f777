public class Student implements Comparable<Student> {
    private String dept;
    private int id;
    private String name;

    public Student(String dept, int id, String name) {
        this.dept = dept;
        this.id = id;
        this.name = name;
    }

    @Override
    public int compareTo(Student other) {
        return this.id - other.id;
    }

    @Override
    public String toString() {
        return dept + "/" + id + "/" + name;
    }
}